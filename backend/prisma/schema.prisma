// Este es tu esquema de Prisma, define las tablas de la base de datos.
// Documentación: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (Listas de valores permitidos)
// ==========================================

enum EstadoAsistencia {
  PRESENTE
  AUSENTE
  JUSTIFICADO
}

enum RolUsuario {
  ADMINISTRADOR
  PROFESOR
  PADRE
}

// ==========================================
// MODELOS / TABLAS
// ==========================================

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  email     String?  @unique
  password  String?  // Se añadirá seguridad luego, es opcional por ahora
  rol       RolUsuario @default(PADRE)
  dni       String?  @unique // Útil para login rápido de padres

  // Un profesor puede tener varios clubes a su cargo
  clubes    Club[]   @relation("ProfesorClub")
  
  // Relación con Alumno (un padre tiene varios hijos)
  hijos     Alumno[] @relation("PadreAlumno")

  // Relación con Notificaciones
  notificaciones Notificacion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Club {
  id          Int      @id @default(autoincrement())
  nombre      String
  descripcion String?
  
  horario     Json?
  
  // Relación: Todo club tiene un profesor a cargo
  profesorId  Int
  profesor    Usuario  @relation("ProfesorClub", fields: [profesorId], references: [id])

  inscripciones Inscripcion[]
  sesiones      Sesion[]
  pagos         Pago[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Alumno {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  grado     String   // Ej: "1ro Secundaria"
  
  // Relación: Un alumno tiene un padre responsable en el sistema
  padreId   Int?     
  padre     Usuario? @relation("PadreAlumno", fields: [padreId], references: [id])

  inscripciones Inscripcion[]
  asistencias   Asistencia[]
  pagos         Pago[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabla intermedia: Qué alumno está en qué club
model Inscripcion {
  id        Int      @id @default(autoincrement())
  
  alumnoId  Int
  alumno    Alumno   @relation(fields: [alumnoId], references: [id])
  
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])

  fechaInscripcion DateTime @default(now())

  // Validacion: Un alumno no puede estar inscrito 2 veces en el mismo club exacto
  @@unique([alumnoId, clubId]) 
}

// Cada vez que un profesor "Abre lista" se crea una Sesion
model Sesion {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @default(now())
  tema      String?  // Ej: "Práctica de tiros libres"
  
  clubId    Int
  club      Club     @relation(fields: [clubId], references: [id])
  
  asistencias Asistencia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// El registro exacto de si vino o no vino
model Asistencia {
  id        Int      @id @default(autoincrement())
  estado    EstadoAsistencia
  
  sesionId  Int
  sesion    Sesion   @relation(fields: [sesionId], references: [id])
  
  alumnoId  Int
  alumno    Alumno   @relation(fields: [alumnoId], references: [id])

  observacion String? // Ej: "Llegó tarde 15 min"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Validacion: Un alumno solo debe tener un registro de asistencia por sesión
  @@unique([sesionId, alumnoId]) 
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  RECHAZADO
}

model Pago {
  id            Int          @id @default(autoincrement())
  mes           String       // Ej: "Abril 2025"
  monto         Float?
  estado        EstadoPago   @default(PENDIENTE)
  urlComprobante String?     // URL o path de la imagen subida
  observacion   String?      // Nota del admin al rechazar/aprobar

  alumnoId      Int
  alumno        Alumno       @relation(fields: [alumnoId], references: [id])

  clubId        Int
  club          Club         @relation(fields: [clubId], references: [id])

  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  titulo    String
  mensaje   String
  tipo      String   @default("INFO") // INFO, PAGO, ASISTENCIA
  leida     Boolean  @default(false)
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt DateTime @default(now())
}
